{
  "name": "firefox",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/background.ts --bundle --platform=browser --target=firefox109 --outfile=background.js",
    "watch": "esbuild src/background.ts --bundle --platform=browser --target=firefox109 --outfile=background.js --watch",
    "run:ext": "web-ext run --firefox-binary='/Applications/Firefox.app/Contents/MacOS/firefox' --firefox-profile=../../profiles/firefox-dev --keep-profile-changes --start-url='about:debugging#/runtime/this-firefox'",
    "lint": "web-ext lint --config web-ext-config.mjs",
    "test": "echo \"Extension tests run via web-ext lint\" && pnpm run lint",
    "build:xpi": "web-ext build --config web-ext-config.mjs --overwrite-dest",
    "sign:unlisted": "web-ext sign --channel=unlisted --config web-ext-config.mjs",
    "sign:listed": "web-ext sign --channel=listed --config web-ext-config.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.28.0",
    "web-ext": "^10.1.0"
  }
}
