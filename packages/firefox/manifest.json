{
  "manifest_version": 3,
  "name": "Firestorm",
  "version": "0.1.1",
  "description": "IPC bridge between Firefox and Thunderbird",
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "nativeMessaging"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "firestorm-firefox@me.digitalby",
      "strict_min_version": "109.0"
    }
  }
}
